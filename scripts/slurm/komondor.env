# Komondor HPC environment — sourced by every SLURM script.
# Edit ACCOUNT / PROJECT / SCRATCH once and every job follows.

# Project identity
export AKI_ACCOUNT="${AKI_ACCOUNT:-pr_2026}"
export AKI_PROJECT_DIR="${AKI_PROJECT_DIR:-/project/pr_2026/aki}"
export AKI_SCRATCH_DIR="${AKI_SCRATCH_DIR:-/scratch/pr_2026/aki}"

# Python toolchain
export AKI_PY_MODULE="${AKI_PY_MODULE:-cray-python/3.11.7}"
export AKI_VENV="${AKI_VENV:-$AKI_PROJECT_DIR/envs/aki-venv}"

# Pipeline storage layout
# Hot I/O (DuckDB + working parquet) lives on fast scratch.
# Durable artifacts (MLflow, reports, tuned params) live on project.
export AKI_RAW_DIR="${AKI_RAW_DIR:-$AKI_PROJECT_DIR/data/raw}"
export AKI_DUCKDB_PATH="${AKI_DUCKDB_PATH:-$AKI_SCRATCH_DIR/mimic.duckdb}"
export AKI_DUCKDB_TEMP_DIR="${AKI_DUCKDB_TEMP_DIR:-$AKI_SCRATCH_DIR/duckdb_tmp}"
export AKI_CURATED_DIR="${AKI_CURATED_DIR:-$AKI_SCRATCH_DIR/curated}"
export AKI_DATA_DIR="${AKI_DATA_DIR:-$AKI_SCRATCH_DIR}"
export AKI_REPORTS_DIR="${AKI_REPORTS_DIR:-$AKI_PROJECT_DIR/reports}"
export AKI_MLFLOW_URI="${AKI_MLFLOW_URI:-file:$AKI_PROJECT_DIR/mlruns}"

# Determinism / threading
# Pin BLAS/OpenMP threads so Optuna trials don't oversubscribe the node.
export OMP_NUM_THREADS="${SLURM_CPUS_PER_TASK:-1}"
export OPENBLAS_NUM_THREADS="${SLURM_CPUS_PER_TASK:-1}"
export MKL_NUM_THREADS="${SLURM_CPUS_PER_TASK:-1}"
export NUMEXPR_NUM_THREADS="${SLURM_CPUS_PER_TASK:-1}"
export PYTHONHASHSEED=42

# Working dir + activation
aki_activate() {
    set -euo pipefail
    module purge
    module load "$AKI_PY_MODULE"
    # shellcheck disable=SC1091
    source "$AKI_VENV/bin/activate"
    cd "$AKI_PROJECT_DIR"
    mkdir -p "$AKI_SCRATCH_DIR" "$AKI_REPORTS_DIR" logs
    echo "[komondor] account=$AKI_ACCOUNT  project=$AKI_PROJECT_DIR  scratch=$AKI_SCRATCH_DIR"
    echo "[komondor] venv=$AKI_VENV  cpus=${SLURM_CPUS_PER_TASK:-?}  job=${SLURM_JOB_ID:-interactive}"
}
